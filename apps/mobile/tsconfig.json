{
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "types": ["expo", "react-native"],

    "paths": {
      "@mobileSrc/*": ["src/*"],
      "@mobileStyles/*": ["src/styles/*"],
      "@mobileTheme/*": ["src/theme/*"],
      "@bt/shared/*": ["../../shared/*"]
    }
  },
  "include": ["src", "../../shared"]
}
